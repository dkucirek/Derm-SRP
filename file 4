# Subclinical Depression Analysis
subclinical_table <- table(
  Group = ifelse(patient_depression_status$is_chronic_derm, "Chronic Derm", "Control"),
  Subclinical = ifelse(patient_depression_status$ever_subclinical, "Subclinical (5-9)", "Not Subclinical")
)
