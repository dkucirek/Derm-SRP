### Depression Outcomes Analysis

```{r}
matched_data <- readRDS(file.path(data_path, "matched_patient_data.rds"))
setDT(matched_data)

matched_mrns <- unique(matched_data$mrn_deid)
outcome_data <- result_wide_all[mrn_deid %in% matched_mrns]
outcome_data <- merge(outcome_data, matched_data[, .(mrn_deid, is_chronic_derm)], by = "mrn_deid", all.x = TRUE)

# Patient-level depression status
patient_depression_status <- outcome_data[, .(
  ever_clinical = any(phq_clinical, na.rm = TRUE),
  ever_subclinical = any(phq_subclinical, na.rm = TRUE),
  max_phq_score = if(any(!is.na(phq_score))) max(phq_score, na.rm = TRUE) else NA_real_,
  has_phq_data = any(!is.na(phq_score))
), by = .(mrn_deid, is_chronic_derm)]

# ===== PI FEEDBACK #2: Add PHQ Severity Categories =====
patient_depression_status[, phq_severity := fcase(
  is.na(max_phq_score), "No PHQ Data",
  max_phq_score >= 15, "Severe (15+)",
  max_phq_score >= 10, "Moderate (10-14)",
  max_phq_score >= 5, "Mild (5-9)",
  max_phq_score < 5, "Minimal (<5)"
)]

cat("\n=== PI FEEDBACK #2: PHQ SEVERITY CATEGORIES ===\n")
severity_summary <- patient_depression_status[, .N, by = .(is_chronic_derm, phq_severity)]
print(severity_summary)

# Clinical Depression Analysis
clinical_table <- table(
  Group = ifelse(patient_depression_status$is_chronic_derm, "Chronic Derm", "Control"),
  Clinical = ifelse(patient_depression_status$ever_clinical, "Clinical (10+)", "Not Clinical")
)
clinical_table <- clinical_table[, c("Clinical (10+)", "Not Clinical")]

cat("\nClinical Depression (≥10):\n")
print(clinical_table)
clinical_gt <- create_comparison_table(clinical_table, "Clinical Depression in Matched Cohort", "PHQ Score ≥10")
