### ===== PI FEEDBACK #3: Demographic Logistic Regression =====

```{r}
cat("\n=== PI FEEDBACK #3: LOGISTIC REGRESSION ANALYSIS ===\n")


# Merge depression data with demographics
patient_demo <- merge(patient_depression_status, 
                     result_info[, .(mrn_deid, age_at_encounter, sex, race_refined, ethnic_refined, fin_class)], 
                     by = "mrn_deid", all.x = FALSE)

# Only chronic derm patients with PHQ data
chronic_derm_demo <- patient_demo[is_chronic_derm == TRUE & has_phq_data == TRUE]

cat("Analyzing", nrow(chronic_derm_demo), "chronic derm patients with PHQ data\n\n")

# === TABLE 3: CLINICAL DEPRESSION DEMOGRAPHIC LOGISTIC REGRESSION ===
cat("--- Table 3: Clinical Depression Demographics (Logistic Regression) ---\n\n")

clinical_demo_results <- list()

# Sex (Male vs Female)
if(length(unique(chronic_derm_demo$sex)) >= 2) {
  sex_model <- glm(ever_clinical ~ sex, data = chronic_derm_demo[sex %in% c("Male", "Female")], family = binomial)
  sex_summary <- summary(sex_model)
  
  if("sexMale" %in% rownames(coef(sex_summary))) {
    sex_coef <- coef(sex_summary)["sexMale", ]
    sex_or <- exp(sex_coef[1])
    sex_ci <- exp(confint(sex_model)["sexMale", ])
    sex_p <- sex_coef[4]
    
    male_data <- chronic_derm_demo[sex == "Male"]
    female_data <- chronic_derm_demo[sex == "Female"]
    male_rate <- sum(male_data$ever_clinical) / nrow(male_data)
    female_rate <- sum(female_data$ever_clinical) / nrow(female_data)
    
    clinical_demo_results[["Sex"]] <- data.frame(
      Variable = "Sex",
      Comparison = "Male vs Female",
      Group1 = paste0(sum(male_data$ever_clinical), "/", nrow(male_data), " (", round(male_rate*100, 1), "%)"),
      Group2 = paste0(sum(female_data$ever_clinical), "/", nrow(female_data), " (", round(female_rate*100, 1), "%)"),
      OR_CI = paste0(round(sex_or, 2), " (", round(sex_ci[1], 2), "-", round(sex_ci[2], 2), ")"),
      P_Value = format_pvalue(sex_p)
    )
  }
}

# Age (<65 vs ≥65)
chronic_derm_demo[, age_65plus := age_at_encounter >= 65]
if(length(unique(chronic_derm_demo$age_65plus)) == 2) {
  age_model <- glm(ever_clinical ~ age_65plus, data = chronic_derm_demo, family = binomial)
  age_summary <- summary(age_model)
  
  if("age_65plusTRUE" %in% rownames(coef(age_summary))) {
    age_coef <- coef(age_summary)["age_65plusTRUE", ]
    age_or <- exp(age_coef[1])
    age_ci <- exp(confint(age_model)["age_65plusTRUE", ])
    age_p <- age_coef[4]
    
    under65_data <- chronic_derm_demo[age_65plus == FALSE]
    over65_data <- chronic_derm_demo[age_65plus == TRUE]
    under65_rate <- sum(under65_data$ever_clinical) / nrow(under65_data)
    over65_rate <- sum(over65_data$ever_clinical) / nrow(over65_data)
    
    clinical_demo_results[["Age"]] <- data.frame(
      Variable = "Age",
      Comparison = "≥65 vs <65",
      Group1 = paste0(sum(over65_data$ever_clinical), "/", nrow(over65_data), " (", round(over65_rate*100, 1), "%)"),
      Group2 = paste0(sum(under65_data$ever_clinical), "/", nrow(under65_data), " (", round(under65_rate*100, 1), "%)"),
      OR_CI = paste0(round(age_or, 2), " (", round(age_ci[1], 2), "-", round(age_ci[2], 2), ")"),
      P_Value = format_pvalue(age_p)
    )
  }
}

# Race (Black vs White)
if(all(c("Black or African American", "White") %in% unique(chronic_derm_demo$race_refined))) {
  race_subset <- chronic_derm_demo[race_refined %in% c("Black or African American", "White")]
  race_subset[, race_black := race_refined == "Black or African American"]
  
  race_model <- glm(ever_clinical ~ race_black, data = race_subset, family = binomial)
  race_summary <- summary(race_model)
  
  if("race_blackTRUE" %in% rownames(coef(race_summary))) {
    race_coef <- coef(race_summary)["race_blackTRUE", ]
    race_or <- exp(race_coef[1])
    race_ci <- exp(confint(race_model)["race_blackTRUE", ])
    race_p <- race_coef[4]
    
    black_data <- race_subset[race_black == TRUE]
    white_data <- race_subset[race_black == FALSE]
    black_rate <- sum(black_data$ever_clinical) / nrow(black_data)
    white_rate <- sum(white_data$ever_clinical) / nrow(white_data)
    
    clinical_demo_results[["Race"]] <- data.frame(
      Variable = "Race",
      Comparison = "Black vs White",
      Group1 = paste0(sum(black_data$ever_clinical), "/", nrow(black_data), " (", round(black_rate*100, 1), "%)"),
      Group2 = paste0(sum(white_data$ever_clinical), "/", nrow(white_data), " (", round(white_rate*100, 1), "%)"),
      OR_CI = paste0(round(race_or, 2), " (", round(race_ci[1], 2), "-", round(race_ci[2], 2), ")"),
      P_Value = format_pvalue(race_p)
    )
  }
}

# Insurance (Medicaid vs Private)
if(all(c("Medicaid", "Private Payors") %in% unique(chronic_derm_demo$fin_class))) {
  insurance_subset <- chronic_derm_demo[fin_class %in% c("Medicaid", "Private Payors")]
  insurance_subset[, medicaid := fin_class == "Medicaid"]
  
  insurance_model <- glm(ever_clinical ~ medicaid, data = insurance_subset, family = binomial)
  insurance_summary <- summary(insurance_model)
  
  if("medicaidTRUE" %in% rownames(coef(insurance_summary))) {
    ins_coef <- coef(insurance_summary)["medicaidTRUE", ]
    ins_or <- exp(ins_coef[1])
    ins_ci <- exp(confint(insurance_model)["medicaidTRUE", ])
    ins_p <- ins_coef[4]
    
    medicaid_data <- insurance_subset[medicaid == TRUE]
    private_data <- insurance_subset[medicaid == FALSE]
    medicaid_rate <- sum(medicaid_data$ever_clinical) / nrow(medicaid_data)
    private_rate <- sum(private_data$ever_clinical) / nrow(private_data)
    
    clinical_demo_results[["Insurance"]] <- data.frame(
      Variable = "Insurance",
      Comparison = "Medicaid vs Private",
      Group1 = paste0(sum(medicaid_data$ever_clinical), "/", nrow(medicaid_data), " (", round(medicaid_rate*100, 1), "%)"),
      Group2 = paste0(sum(private_data$ever_clinical), "/", nrow(private_data), " (", round(private_rate*100, 1), "%)"),
      OR_CI = paste0(round(ins_or, 2), " (", round(ins_ci[1], 2), "-", round(ins_ci[2], 2), ")"),
      P_Value = format_pvalue(ins_p)
    )
  }
}

# Create Table 3
if(length(clinical_demo_results) > 0) {
  clinical_demo_df <- do.call(rbind, clinical_demo_results)
  
  table3_clinical <- clinical_demo_df %>%
    gt() %>%
    tab_header(
      title = "Table 3: Clinical Depression Demographic Comparisons (Logistic Regression)",
      subtitle = "Within chronic derm cohort - PHQ ≥10"
    ) %>%
    cols_label(
      Variable = "Variable",
      Comparison = "Comparison",
      Group1 = "Group 1",
      Group2 = "Group 2",
      OR_CI = "OR (95% CI)",
      P_Value = "P"
    ) %>%
    tab_options(
      table.border.top.color = "#495057",
      table.border.bottom.color = "#495057",
      column_labels.font.weight = "bold"
    )
  
  print(table3_clinical)
  
  # Save CSV
  csv_dir <- "C:/Users/dkucirek/Documents/Derm-SRP/As CSV"
  if (!dir.exists(csv_dir)) dir.create(csv_dir, recursive = TRUE)
  write.csv(clinical_demo_df, file.path(csv_dir, "Table_3_Clinical_Demographics_Logistic.csv"), row.names = FALSE)
}

