## =====  Bonferroni Correction for Pairwise Comparisons =====

```{r}
cat("\n===  BONFERRONI CORRECTION ===\n")

# Calculate all pairwise comparisons
condition_names <- names(condition_cohorts)
n_conditions <- length(condition_names)
n_comparisons <- choose(n_conditions, 2)

cat("Number of conditions:", n_conditions, "\n")
cat("Number of pairwise comparisons:", n_comparisons, "\n")

# DR. L FEEDBACK: Apply Bonferroni correction
bonferroni_threshold <- 0.05 / n_comparisons
cat("Bonferroni-corrected p-value threshold:", format_pvalue(bonferroni_threshold), "\n\n")

pairwise_results <- data.table()

for(i in 1:(n_conditions-1)) {
  for(j in (i+1):n_conditions) {
    condition1 <- condition_names[i]
    condition2 <- condition_names[j]
    
    # Get matched patient IDs for both conditions
    cohort1 <- condition_cohorts[[condition1]]
    cohort2 <- condition_cohorts[[condition2]]
    
    cond1_ids <- cohort1$after_matching[treat == 1, mrn_deid]
    cond2_ids <- cohort2$after_matching[treat == 1, mrn_deid]
    
    # Get PHQ data
    cond1_phq <- result_wide_all[mrn_deid %in% cond1_ids, .(
      ever_clinical = any(phq_clinical, na.rm = TRUE)
    ), by = mrn_deid]
    
    cond2_phq <- result_wide_all[mrn_deid %in% cond2_ids, .(
      ever_clinical = any(phq_clinical, na.rm = TRUE)
    ), by = mrn_deid]
    
    # Create contingency table
    comparison_table <- matrix(c(
      sum(cond1_phq$ever_clinical),
      nrow(cond1_phq) - sum(cond1_phq$ever_clinical),
      sum(cond2_phq$ever_clinical),
      nrow(cond2_phq) - sum(cond2_phq$ever_clinical)
    ), nrow = 2, byrow = TRUE)
    
    # Fisher's exact test (better for small samples)
    fisher_test <- fisher.test(comparison_table)
    
    # Calculate OR
    or_result <- tryCatch({
      epitools::oddsratio(comparison_table)
    }, error = function(e) NULL)
    
    # Mark significance with Bonferroni correction
    is_significant <- fisher_test$p.value < bonferroni_threshold
    
    pairwise_results <- rbind(pairwise_results, data.table(
      Comparison = paste(condition1, "vs", condition2),
      Condition1 = condition1,
      Condition2 = condition2,
      Cond1_Clinical_n = sum(cond1_phq$ever_clinical),
      Cond1_N = nrow(cond1_phq),
      Cond1_Rate = round(mean(cond1_phq$ever_clinical) * 100, 1),
      Cond2_Clinical_n = sum(cond2_phq$ever_clinical),
      Cond2_N = nrow(cond2_phq),
      Cond2_Rate = round(mean(cond2_phq$ever_clinical) * 100, 1),
      OR = if(!is.null(or_result)) round(or_result$measure[2,1], 2) else NA,
      CI_lower = if(!is.null(or_result)) round(or_result$measure[2,2], 2) else NA,
      CI_upper = if(!is.null(or_result)) round(or_result$measure[2,3], 2) else NA,
      P_Value = fisher_test$p.value,
      Bonferroni_Significant = is_significant
    ))
  }
}

# Sort by p-value
pairwise_results <- pairwise_results[order(P_Value)]

# Count significant comparisons
n_significant_uncorrected <- sum(pairwise_results$P_Value < 0.05)
n_significant_bonferroni <- sum(pairwise_results$Bonferroni_Significant)

cat("\n=== BONFERRONI CORRECTION RESULTS ===\n")
cat("Comparisons significant at p<0.05 (uncorrected):", n_significant_uncorrected, "\n")
cat("Comparisons significant after Bonferroni correction (p<", format_pvalue(bonferroni_threshold), "):", n_significant_bonferroni, "\n")

if(n_significant_bonferroni == 0) {
  cat("\n NO comparisons remain significant after Bonferroni correction\n")
}

# Create table
pairwise_table_data <- pairwise_results %>%
  mutate(
    Cond1_Display = paste0(Cond1_Clinical_n, "/", Cond1_N, " (", Cond1_Rate, "%)"),
    Cond2_Display = paste0(Cond2_Clinical_n, "/", Cond2_N, " (", Cond2_Rate, "%)"),
    OR_CI = paste0(OR, " (", CI_lower, "-", CI_upper, ")"),
    Significance = ifelse(Bonferroni_Significant, "Yes*", 
                         ifelse(P_Value < 0.05, "No (p<0.05 uncorrected)", "No"))
  ) %>%
  select(Comparison, Cond1_Display, Cond2_Display, OR_CI, P_Value, Significance, Bonferroni_Significant)

pairwise_table <- pairwise_table_data %>%
  gt() %>%
  tab_header(
    title = "Table 4. Pairwise Clinical Depression Comparisons Between Conditions",
