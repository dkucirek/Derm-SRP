cat("\n===  COMBINED CLINICAL/SUBCLINICAL TABLE ===\n")


# Helper function to validate PHQ data
validate_clinical_phq_data <- function(dt) {
  required_cols <- c("phq_score", "phq_clinical", "phq_subclinical")
  missing_cols <- setdiff(required_cols, names(dt))
  
  if (length(missing_cols) > 0) {
    warning(paste("Missing PHQ columns:", paste(missing_cols, collapse = ", ")))
  }
  
  if (!"phq_clinical" %in% names(dt)) {
    dt[, phq_clinical := phq_score >= 10 & !is.na(phq_score)]
  }
  if (!"phq_subclinical" %in% names(dt)) {
    dt[, phq_subclinical := phq_score >= 5 & phq_score <= 9 & !is.na(phq_score)]
  }
  
  return(dt)
}

# PHQ outcome analysis for each condition
condition_phq_results <- data.table()

for (condition_name in names(condition_cohorts)) {
  cat("\n--- Analyzing", condition_name, "---\n")
  
  cohort_data <- condition_cohorts[[condition_name]]
  matched_patients <- cohort_data$after_matching
  
  condition_patient_ids <- matched_patients[treat == 1, mrn_deid]
  control_patient_ids <- matched_patients[treat == 0, mrn_deid]
  
  # Get PHQ data
  condition_encounters <- result_wide_all[mrn_deid %in% condition_patient_ids]
  condition_encounters <- validate_clinical_phq_data(condition_encounters)
  
  control_encounters <- result_wide_all[mrn_deid %in% control_patient_ids]
  control_encounters <- validate_clinical_phq_data(control_encounters)
  
  # Patient-level analysis
  condition_phq_status <- condition_encounters[, .(
    ever_clinical = any(phq_clinical, na.rm = TRUE),
    ever_subclinical = any(phq_subclinical, na.rm = TRUE)
  ), by = mrn_deid]
  condition_phq_status[, group := condition_name]
  
  control_phq_status <- control_encounters[, .(
    ever_clinical = any(phq_clinical, na.rm = TRUE),
    ever_subclinical = any(phq_subclinical, na.rm = TRUE)
  ), by = mrn_deid]
  control_phq_status[, group := "Control"]
  
  # Calculate statistics
  clinical_matrix <- matrix(c(
    sum(condition_phq_status$ever_clinical),
    nrow(condition_phq_status) - sum(condition_phq_status$ever_clinical),
    sum(control_phq_status$ever_clinical),
    nrow(control_phq_status) - sum(control_phq_status$ever_clinical)
  ), nrow = 2, byrow = TRUE)
  
  subclinical_matrix <- matrix(c(
    sum(condition_phq_status$ever_subclinical),
    nrow(condition_phq_status) - sum(condition_phq_status$ever_subclinical),
    sum(control_phq_status$ever_subclinical),
    nrow(control_phq_status) - sum(control_phq_status$ever_subclinical)
  ), nrow = 2, byrow = TRUE)
  
  clinical_chi <- chisq.test(clinical_matrix)
  subclinical_chi <- chisq.test(subclinical_matrix)
  
  clinical_or <- epitools::oddsratio(clinical_matrix)
  subclinical_or <- epitools::oddsratio(subclinical_matrix)
  
  # Store results
  condition_phq_results <- rbind(condition_phq_results, data.table(
    Condition = condition_name,
    N = nrow(condition_phq_status),
    Control_N = nrow(control_phq_status),
    # Subclinical (LEFT side)
    Subclinical_n = sum(condition_phq_status$ever_subclinical),
    Subclinical_pct = round(mean(condition_phq_status$ever_subclinical) * 100, 1),
    Control_Subclinical_n = sum(control_phq_status$ever_subclinical),
    Control_Subclinical_pct = round(mean(control_phq_status$ever_subclinical) * 100, 1),
    Subclinical_OR = round(subclinical_or$measure[2,1], 2),
    Subclinical_CI_lower = round(subclinical_or$measure[2,2], 2),
    Subclinical_CI_upper = round(subclinical_or$measure[2,3], 2),
    Subclinical_P = subclinical_chi$p.value,
    # Clinical (RIGHT side)
    Clinical_n = sum(condition_phq_status$ever_clinical),
    Clinical_pct = round(mean(condition_phq_status$ever_clinical) * 100, 1),
    Control_Clinical_n = sum(control_phq_status$ever_clinical),
    Control_Clinical_pct = round(mean(control_phq_status$ever_clinical) * 100, 1),
    Clinical_OR = round(clinical_or$measure[2,1], 2),
    Clinical_CI_lower = round(clinical_or$measure[2,2], 2),
    Clinical_CI_upper = round(clinical_or$measure[2,3], 2),
    Clinical_P = clinical_chi$p.value
  ))
}

# Combined table with subclinical LEFT of clinical
combined_table_data <- condition_phq_results %>%
  mutate(
