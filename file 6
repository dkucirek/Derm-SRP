format_pvalue_single <- function(p) {
  if (is.na(p)) return("NA")
  if (p < 0.001) return("<0.001")
  if (p >= 0.001 & p <= 0.004) return(sprintf("%.3f", p))
  if (p >= 0.045 & p <= 0.049) return(sprintf("%.3f", p))
  return(sprintf("%.2f", p))
}

